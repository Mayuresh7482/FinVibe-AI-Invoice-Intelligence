# ╔══════════════════════════════════════════════════════════════════╗
# ║  FinVibe — Environment Configuration                            ║
# ║  Copy this file to .env and fill in your values.                ║
# ║  ⚠️  NEVER commit .env with real secrets to version control.    ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Django Core ─────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=finvibe.settings.local
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ─── AI Service (Gemini) ────────────────────────────────────────
# Get your key: https://makersuite.google.com/app/apikey
# Production: store in secret manager (AWS/GCP/Vault), not here.
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-1.5-flash
AI_CONFIDENCE_THRESHOLD=0.6
AI_MAX_RETRIES=3
AI_REQUEST_TIMEOUT=30

# ─── Demo Mode ───────────────────────────────────────────────────
# True = uses fallback parser (zero API cost). Safe default.
# Set False only when GEMINI_API_KEY is configured and ready.
DEMO_MODE=True

# ─── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PARSE_PER_MINUTE=5
MAX_RAW_TEXT_LENGTH=50000

# ─── Database ────────────────────────────────────────────────────
# Dev: SQLite (automatic via local.py, no config needed)
# Prod: PostgreSQL (configure below + use production.py)
DATABASE_URL=sqlite:///db.sqlite3
DB_NAME=finvibe_db
DB_USER=finvibe_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ─── Sentry (Error Tracking) ────────────────────────────────────
SENTRY_DSN=

# ─── Notes ───────────────────────────────────────────────────────
# 1. GEMINI_API_KEY → move to CI/CD secrets for production
# 2. SECRET_KEY → generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# 3. Set DEBUG=False, DEMO_MODE=False for production
# 4. Configure HTTPS + HSTS (automatic in production.py)
# 5. Set budget alerts on Google Cloud for Gemini API usage
